@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses() panel transition-all duration-150"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 neon-text text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-2 text-center rounded select-none min-h-[60px] text-sm leading-tight";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-amber-200 border-amber-400 text-amber-900"
                : "bg-black/50 border-marked-border neon-text"
            : "bg-transparent border border-gray-700 text-muted";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-bold text-sm neon-text" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
