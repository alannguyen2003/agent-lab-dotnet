@using SocOps.Models

<div class="flex flex-col min-h-full">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 panel mb-4">
        <button
            @onclick="OnReset"
            class="text-muted text-sm px-3 py-1.5 rounded transition-all">
            ← Back
        </button>
        <h1 class="font-bold neon-text">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-muted text-sm py-2 px-4">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="panel text-center py-2 font-semibold text-sm neon-text">🎉 BINGO! You got a line!</div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <div class="panel p-4 max-w-md w-full">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
