<div class="flex flex-col items-center justify-center min-h-full p-6">
    <div class="text-center max-w-sm w-full">
        <h1 class="text-4xl font-bold neon-text mb-2">Soc Ops</h1>
        <p class="text-lg text-muted mb-8">Social Bingo</p>

        <div class="panel rounded-lg p-6 mb-8">
            <h2 class="font-semibold neon-text mb-3">How to play</h2>
            <ul class="text-left text-muted text-sm space-y-2">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full btn btn-accent font-semibold py-4 px-8 rounded-lg text-lg shadow-sm transition-all duration-150">
            Start Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
