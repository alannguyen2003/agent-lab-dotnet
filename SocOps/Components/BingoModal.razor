<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    @inject IJSRuntime JS

    <div class="panel rounded-xl p-6 max-w-xs w-full text-center animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4 neon-text">🎉</div>
        <h2 class="text-3xl font-bold neon-text mb-2">BINGO!</h2>
        <p class="text-muted mb-6">You completed a line!</p>

        <button
            @onclick="OnDismiss"
                class="w-full btn btn-accent font-semibold py-3 px-6 rounded-lg transition-all duration-150">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }

    private bool _launched;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_launched)
        {
            _launched = true;
            try { await JS.InvokeVoidAsync("confetti.launch"); } catch { }
        }
    }
}
